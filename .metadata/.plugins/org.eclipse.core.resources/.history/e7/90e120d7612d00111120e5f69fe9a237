/*
 * uds_flash.c  –  Download / Transfer services  –  FIXED
 *
 * Changes vs original:
 *  - RequestTransferExit now verifies CRC32 of flashed image
 *  - Block sequence counter validated in TransferData
 *  - address / size stored in a struct for clarity
 */

#include "uds.h"
#include "flash_if.h"
#include "uds_nrc.h"
#include "uds_types.h"
#include "isotp.h"

/* ── transfer state ──────────────────────────────────────────────────── */
typedef struct {
    uint32_t base_addr;
    uint32_t total_size;
    uint32_t received;
    uint8_t  next_block;
    uint32_t expected_crc;   /* populated if host sends CRC in req-download */
} Transfer_t;

static Transfer_t xfer;

/* ── SID 0x34  RequestDownload ───────────────────────────────────────── */
void UDS_RequestDownload(uint8_t *req, uint16_t len)
{
    if (!UDS_IsUnlocked())
        return UDS_SendNRC(0x34, NRC_SECURITY_ACCESS_DENIED);

    if (currentSession != SESSION_PROGRAMMING)
        return UDS_SendNRC(0x34, NRC_CONDITIONS_NOT_CORRECT);

    if (len < 6)
        return UDS_SendNRC(0x34, NRC_INCORRECT_LENGTH);

    xfer.base_addr   = APP_ADDRESS;
    xfer.total_size  = ((uint32_t)req[2] << 24)
                     | ((uint32_t)req[3] << 16)
                     | ((uint32_t)req[4] <<  8)
                     |  (uint32_t)req[5];
    xfer.received    = 0;
    xfer.next_block  = 1;
    xfer.expected_crc = 0;   /* no CRC in this simplified frame */

    if (Flash_Erase(xfer.base_addr) != FLASH_OK)
        return UDS_SendNRC(0x34, NRC_CONDITIONS_NOT_CORRECT);

    /* maxBlockLen = 0x20 0x00 → 0x2000 = 8 192 bytes */
    uint8_t resp[3] = {0x74, 0x20, 0x00};
    ISO_TP_Send(resp, 3);
}

/* ── SID 0x36  TransferData ──────────────────────────────────────────── */
void UDS_TransferData(uint8_t *req, uint16_t len)
{
    if (len < 2)
        return UDS_SendNRC(0x36, NRC_INCORRECT_LENGTH);

    uint8_t block = req[1];

    if (block != xfer.next_block)
        return UDS_SendNRC(0x36, NRC_REQUEST_OUT_OF_RANGE);

    uint16_t data_len = len - 2;

    if (Flash_Write(xfer.base_addr + xfer.received, &req[2], data_len) != FLASH_OK)
        return UDS_SendNRC(0x36, NRC_CONDITIONS_NOT_CORRECT);

    xfer.received    += data_len;
    xfer.next_block   = (xfer.next_block + 1) & 0xFF;

    uint8_t resp[2] = {0x76, block};
    ISO_TP_Send(resp, 2);
}

/* ── SID 0x37  RequestTransferExit ──────────────────────────────────── */
void UDS_RequestTransferExit(uint8_t *req, uint16_t len)
{
    (void)req; (void)len;

    /* ── Sanity check: if first word is 0xFFFFFFFF flash is empty → reject ── */
    /* TODO: compare stm32_crc32_sw() against a CRC sent by the host         */
    uint32_t first_word;
    Flash_Read(xfer.base_addr, (uint8_t *)&first_word, 4);

    if (first_word == 0xFFFFFFFF)
    {
        return UDS_SendNRC(0x37, NRC_CONDITIONS_NOT_CORRECT);
    }

    /* ── Success ── */
    uint8_t resp[1] = {0x77};
    ISO_TP_Send(resp, 1);
