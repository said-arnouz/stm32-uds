#include "isotp.h"
#include "uds.h"
#include "flash_if.h"
#include "string.h"

extern UART_HandleTypeDef huart2;
static ISO_TP_Context_t rx_ctx;
static ISO_TP_Context_t tp_rx;
void ISO_TP_Init(void)
{
    memset(&rx_ctx, 0, sizeof(rx_ctx));
}

void ISO_TP_SendFrame(uint8_t *frame)
{
    HAL_UART_Transmit(&huart2, frame, 8, HAL_MAX_DELAY);
}
void ISO_TP_SendFC(void)
{
    uint8_t frame[8] = {0};

    frame[0] = ISO_TP_FC | 0x00; // CTS
    frame[1] = 0x00;             // Block Size (0 = no limit)
    frame[2] = 0x00;             // STmin (no delay)

    ISO_TP_SendFrame(frame);
}
void ISO_TP_Receive(uint8_t *frame)
{
    uint8_t pci = frame[0] & 0xF0;

    if (pci == ISO_TP_SF)
    {
        uint8_t len = frame[0] & 0x0F;
        memcpy(tp_rx.buffer, &frame[1], len);
        tp_rx.length = len;

        UDS_ProcessRequest(tp_rx.buffer, len);
    }
    else if (pci == ISO_TP_FF)
    {
        tp_rx.length = ((frame[0] & 0x0F) << 8) | frame[1];
        memcpy(tp_rx.buffer, &frame[2], 6);
        tp_rx.index = 6;

        ISO_TP_SendFC(); // send flow control
    }
    else if (pci == ISO_TP_CF)
    {
        memcpy(&tp_rx.buffer[tp_rx.index], &frame[1], 7);
        tp_rx.index += 7;

        if (tp_rx.index >= tp_rx.length)
        {
            UDS_ProcessRequest(tp_rx.buffer, tp_rx.length);
        }
    }
}


void ISO_TP_Send(uint8_t *data, uint16_t len)
{
    uint8_t frame[8] = {0};

    /* ========= SINGLE FRAME ========= */
    if(len <= 7)
    {
        frame[0] = ISO_TP_SF | len;
        memcpy(&frame[1], data, len);

        ISO_TP_SendFrame(frame);
    }
    /* ========= MULTI FRAME ========= */
    else
    {
        /* FIRST FRAME */
        frame[0] = ISO_TP_FF | (len >> 8);
        frame[1] = len & 0xFF;

        memcpy(&frame[2], data, 6);
        ISO_TP_SendFrame(frame);

        HAL_Delay(1); // small delay

        uint16_t index = 6;
        uint8_t sn = 1;

        /* CONSECUTIVE */
        while(index < len)
        {
            frame[0] = ISO_TP_CF | (sn++ & 0x0F);

            uint8_t chunk = (len - index > 7) ? 7 : (len - index);
            memcpy(&frame[1], &data[index], chunk);

            ISO_TP_SendFrame(frame);

            index += chunk;

            HAL_Delay(1);
        }
    }
}
void ISO_TP_ProcessFrame(uint8_t *frame)
{
    uint8_t pci_type = frame[0] & 0xF0;

    switch(pci_type)
    {
        /* ================= SINGLE FRAME ================= */
        case ISO_TP_SF:
        {
            uint8_t len = frame[0] & 0x0F;

            memcpy(rx_ctx.buffer, &frame[1], len);
            rx_ctx.length = len;

            UDS_Process(rx_ctx.buffer, len);
        } break;

        /* ================= FIRST FRAME ================= */
        case ISO_TP_FF:
        {
            rx_ctx.length = ((frame[0] & 0x0F) << 8) | frame[1];

            memcpy(rx_ctx.buffer, &frame[2], 6);
            rx_ctx.index = 6;
            rx_ctx.sequence_number = 1;

            ISO_TP_SendFC(); // 🔥 مهم
        } break;

        /* ================= CONSECUTIVE FRAME ================= */
        case ISO_TP_CF:
        {
            uint8_t sn = frame[0] & 0x0F;

            if(sn != (rx_ctx.sequence_number & 0x0F))
            {
                // sequence error
                return;
            }

            rx_ctx.sequence_number++;

            memcpy(&rx_ctx.buffer[rx_ctx.index], &frame[1], 7);
            rx_ctx.index += 7;

            if(rx_ctx.index >= rx_ctx.length)
            {
                UDS_Process(rx_ctx.buffer, rx_ctx.length);
            }
        } break;

        /* ================= FLOW CONTROL ================= */
        case ISO_TP_FC:
        {
            // optional: handle FC if you're sender
        } break;

        default:
            break;
    }
}

void UDS_ProcessRequest(uint8_t *req, uint16_t len)
{
    uint8_t sid = req[0];

    switch(sid)
    {
        case 0x10: UDS_Session(req, len); break;
        case 0x11: UDS_Reset(req, len); break;
        case 0x27: UDS_Security(req, len); break;
        case 0x22: UDS_ReadDID(req, len); break;
        case 0x2E: UDS_WriteDID(req, len); break;

        default:
            UDS_SendNRC(sid, 0x11);
    }
}
uint8_t UDS_IsServiceAllowed(uint8_t sid)
{
    if (ecuMode == ECU_BOOTLOADER)
    {
        return (sid == 0x10 || sid == 0x11 || sid == 0x27 || sid == 0x2E);
    }
    else
    {
        return (sid == 0x10 || sid == 0x11 || sid == 0x22);
    }
}

