#include "uds.h"
#include "flash_if.h"
#include "uds_nrc.h"

static uint32_t flash_addr;
static uint32_t total_size;
static uint32_t received;

void UDS_RequestDownload(uint8_t *req, uint16_t len)
{
    if(!UDS_IsUnlocked())
        return UDS_SendNRC(0x34, NRC_SECURITY_ACCESS_DENIED);

    if(currentSession != SESSION_PROGRAMMING)
        return UDS_SendNRC(0x34, NRC_CONDITIONS_NOT_CORRECT);

    flash_addr = 0x08020000;
    total_size = (req[2]<<24)|(req[3]<<16)|(req[4]<<8)|req[5];
    received = 0;

    Flash_Erase(flash_addr);

    uint8_t resp[3] = {0x74, 0x20, 0x00};
    ISO_TP_Send(resp,3);
}

void UDS_TransferData(uint8_t *req, uint16_t len)
{
    uint8_t block = req[1];

    Flash_Write(flash_addr + received, &req[2], len-2);
    received += (len-2);

    uint8_t resp[2] = {0x76, block};
    ISO_TP_Send(resp,2);
}

void UDS_RequestTransferExit(uint8_t *req, uint16_t len)
{
    uint8_t resp[1] = {0x77};
    ISO_TP_Send(resp,1);
}

