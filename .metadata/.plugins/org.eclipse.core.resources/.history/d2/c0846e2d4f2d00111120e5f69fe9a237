#include "isotp.h"
#include "uds.h"
#include "uds_nrc.h"
#include "string.h"

static uint8_t seed[4] = {0x11,0x22,0x33,0x44};
static uint8_t unlocked = 0;

uint8_t UDS_Security(uint8_t *req, uint16_t len)
{
    if(len < 2)
        return UDS_SendNRC(0x27, NRC_INCORRECT_LENGTH);

    uint8_t sub = req[1];

    switch(sub)
    {
        case 0x01: // request seed
        {
            uint8_t resp[6] = {0x67,0x01,seed[0],seed[1],seed[2],seed[3]};
            ISO_TP_Send(resp,6);
        } break;

        case 0x02: // send key
        {
            if(memcmp(&req[2], seed, 4)==0)
            {
                unlocked = 1;
                uint8_t resp[2] = {0x67,0x02};
                ISO_TP_Send(resp,2);
            }
            else
            {
                UDS_SendNRC(0x27, NRC_INVALID_KEY);
            }
        } break;

        default:
            UDS_SendNRC(0x27, NRC_SUBFUNCTION_NOT_SUPPORTED);
    }
}

uint8_t UDS_IsUnlocked()
{
    return unlocked;
}
