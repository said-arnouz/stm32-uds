

void UDS_ReadDID(uint8_t *req, uint16_t len)
{
    if (len != 3)
        return UDS_SendNRC(0x22, 0x13);

    uint16_t did = (req[1] << 8) | req[2];

    if (did == 0xF186)
    {
        uint8_t resp[] = {0x62, req[1], req[2], 0x12, 0x34};
        ISO_TP_Send(resp, sizeof(resp));
    }
    else
    {
        UDS_SendNRC(0x22, 0x31);
    }
}
