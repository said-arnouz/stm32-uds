/*
 * uds_session.c  –  DiagnosticSessionControl  –  FIXED
 *
 * Changes vs original:
 *  - Calls UDS_ResetSecurity() whenever session changes
 *    (security must be re-established per new session)
 */

#include "uds_types.h"
#include "uds.h"
#include "uds_nrc.h"
#include "isotp.h"

ECU_Mode_t    ecuMode        = ECU_BOOTLOADER;
UDS_Session_t currentSession = SESSION_DEFAULT;

void UDS_Session(uint8_t *req, uint16_t len)
{
    if (len != 2)
        return UDS_SendNRC(0x10, NRC_INCORRECT_LENGTH);

    uint8_t sub = req[1];

    if (ecuMode == ECU_BOOTLOADER)
    {
        /* Bootloader only allows switching to Programming session */
        if (sub != SESSION_PROGRAMMING)
            return UDS_SendNRC(0x10, NRC_SUBFUNCTION_NOT_SUPPORTED);
    }

    /* Lock security whenever session changes */
    if (sub != currentSession)
        UDS_ResetSecurity();

    currentSession = (UDS_Session_t)sub;

    uint8_t resp[3] = {0x50, sub, 0x00};
    ISO_TP_Send(resp, 3);
}
