#include "isotp.h"
#include "uds.h"

void UDS_ProcessRequest(uint8_t *req, uint16_t len)
{
    uint8_t sid = req[0];

    switch(sid)
    {
        case 0x10: UDS_0x10(req, len); break;
        case 0x11: UDS_0x11(req, len); break;
        case 0x27: UDS_0x27(req, len); break;
        case 0x22: UDS_0x22(req, len); break;
        case 0x2E: UDS_0x2E(req, len); break;

        default:
            UDS_SendNRC(sid, 0x11);
    }
}

