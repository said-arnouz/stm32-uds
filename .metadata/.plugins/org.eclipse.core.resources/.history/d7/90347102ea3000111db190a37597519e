#ifndef INC_FLASH_IF_H_
#define INC_FLASH_IF_H_

#include <stdint.h>
#include <string.h>
#include "stm32f4xx_hal.h"

/* DEFINE */
#define APP_ADDRESS 	0x08020000UL
#define MAX_CHUNK       256
#define END_MARKER      0xFFFF
/* STATUS */
typedef enum
{
    FLASH_OK = 0,
    FLASH_ERROR
} FLASH_Status_t;

/* API */
