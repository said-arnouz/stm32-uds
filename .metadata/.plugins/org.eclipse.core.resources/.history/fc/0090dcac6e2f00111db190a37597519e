/*
 * uds.h  –  UDS service declarations
 *
 *  Missing from original project – CubeMX won't generate this,
 *  must be created manually under Core/Inc/.
 */

#ifndef INC_UDS_H_
#define INC_UDS_H_

#include <stdint.h>
#include "uds_types.h"

/* ── NRC helper ─────────────────────────────────────────────────────── */
void UDS_SendNRC(uint8_t sid, uint8_t nrc);

/* ── Router ─────────────────────────────────────────────────────────── */
void UDS_Process(uint8_t *req, uint16_t len);

/* ── Session (0x10) ─────────────────────────────────────────────────── */
void UDS_Session(uint8_t *req, uint16_t len);

/* ── ECU Reset (0x11) ───────────────────────────────────────────────── */
void UDS_Reset(uint8_t *req, uint16_t len);

/* ── Security Access (0x27) ─────────────────────────────────────────── */
void UDS_Security(uint8_t *req, uint16_t len);
uint8_t UDS_IsUnlocked(void);
void    UDS_ResetSecurity(void);   /* call on session change */

/* ── Read DID (0x22) ────────────────────────────────────────────────── */
void UDS_ReadDID(uint8_t *req, uint16_t len);

/* ── Write DID (0x2E) ───────────────────────────────────────────────── */
void UDS_WriteDID(uint8_t *req, uint16_t len);

/* ── Download / Transfer (0x34 / 0x36 / 0x37) ──────────────────────── */
void UDS_RequestDownload(uint8_t *req, uint16_t len);
void UDS_TransferData(uint8_t *req, uint16_t len);
void UDS_RequestTransferExit(uint8_t *req, uint16_t len);

#endif /* INC_UDS_H_ */
