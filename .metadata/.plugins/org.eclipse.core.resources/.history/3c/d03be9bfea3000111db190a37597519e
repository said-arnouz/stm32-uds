/* USER CODE BEGIN 4 */
void SIGMA_SecurityAccess(uint8_t length,uint8_t sub, uint8_t key, uint8_t *tx_buf)
{
    memset(tx_buf, 0xAA, 8);

    if (length > 2 && sub == REQUEST_SEED)
    {
        tx_buf[0] = 0x03;
        tx_buf[1] = NRC;
        tx_buf[2] = SID_SECURITY;
        tx_buf[3] = NRC_SUBFUNCTION_NOT_SUPPORTED;
        UART_Send(tx_buf, 8);
        return;
    }
    else
    {
		// Locked : refuse tout
		if (sec_locked)
		{
			tx_buf[0] = 0x03;
			tx_buf[1] = NRC;
			tx_buf[2] = SID_SECURITY;
			tx_buf[3] = NRC_EXCEEDED_NUMBERS_OF_ATTEMPTS;
			UART_Send(tx_buf, 8);
			return;
		}

		if (sub == REQUEST_SEED)
		{
			sec_seed      = (uint16_t)(HAL_GetTick() & 0xFFFF);// hadi kanqado biha Random seed
			sec_seed_sent = true;// hada bhal flag ntichkiw bih waxh dazna man srv 0x01
			sec_attempts  = 0;
			uint8_t seed_H = (uint8_t)(sec_seed >> 8);
			uint8_t seed_L = (uint8_t)(sec_seed & 0xFF);
			sec_timestamp = HAL_GetTick();

			// [03][67][seed_H][seed_L][AA][AA][AA][AA]
			tx_buf[0] = 0x03;
			tx_buf[1] = SID_SECURITY + POS; // 0x67
			tx_buf[2] = seed_H;
			tx_buf[3] = seed_L;
			UART_Send(tx_buf, 8);
		}
		else if (sub == SEND_KEY)
		{
			if (!sec_seed_sent)
			{
				tx_buf[0] = 0x03;
				tx_buf[1] = NRC;
				tx_buf[2] = SID_SECURITY;
				tx_buf[3] = NRC_REQUEST_SEQUENCE_ERROR;
				UART_Send(tx_buf, 8);
				return;
			}

			if ((HAL_GetTick() - sec_timestamp) > SEC_TIMEOUT_MS) // 1 min li 3andek
			{
				sec_seed_sent = false;
				tx_buf[0] = 0x03;
				tx_buf[1] = NRC;
				tx_buf[2] = SID_SECURITY;
				tx_buf[3] = NRC_REQUIRED_TIME_DELAY_NOT_EXPIRED;
				UART_Send(tx_buf, 8);
				return;
			}

			// XOR seed_H ^ seed_L
			uint8_t expected = (uint8_t)(sec_seed >> 8) ^ (uint8_t)(sec_seed & 0xFF);

			if (key != expected)
			{
				sec_attempts++;
				tx_buf[0] = 0x03;
				tx_buf[1] = NRC;
				tx_buf[2] = SID_SECURITY;
				tx_buf[3] = (sec_attempts >= SEC_MAX_ATTEMPTS) ? NRC_EXCEEDED_NUMBERS_OF_ATTEMPTS : NRC_INVALID_KEY;

				if (sec_attempts >= SEC_MAX_ATTEMPTS)
				{
					sec_locked    = true;
					sec_seed_sent = false;
				}
				UART_Send(tx_buf, 8);
				return;
			}

			// Key correct
			sec_unlocked  = true;
			sec_seed_sent = false;
			sec_attempts  = 0;
			tx_buf[0] = 0x02;
			tx_buf[1] = SID_SECURITY + POS;
			tx_buf[2] = SEND_KEY;
			UART_Send(tx_buf, 8);
		}
		else
		{
			tx_buf[0] = 0x03;
			tx_buf[1] = NRC;
			tx_buf[2] = SID_SECURITY;
			tx_buf[3] = NRC_SUBFUNCTION_NOT_SUPPORTED;
			UART_Send(tx_buf, 8);
		}
    }
}

