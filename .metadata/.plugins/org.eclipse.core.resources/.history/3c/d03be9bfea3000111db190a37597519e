/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  /* USER CODE BEGIN 2 */
  uint8_t tx_buf[8];
  uint8_t frame[8] = {0};
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {

	    // Read LEN first
	    if (HAL_UART_Receive(&huart2, &frame, 1, 1000) != HAL_OK)
	        continue;

	    uint8_t len = frame[0];
	    uint8_t sid  = frame[1];
	    uint8_t sub  = frame[2];
	    uint8_t data = (len >= 3) ? frame[3] : 0x00;

	    memset(tx_buf, 0xAA, 8);

	    // len check
	    if (len < 1 || len > 6)
	    {
	        tx_buf[0] = 0x03;
	        tx_buf[1] = NRC;
	        tx_buf[2] = sid;
	        tx_buf[3] = NRC_INCORRECT_MESSAGE_LENGTH;
	        UART_Send(tx_buf, 8);
	        continue;
	    }

	    if (sid == SID_DIAG_SESSION)
	    {
	    	if(len != 2)
	    	{
				tx_buf[0] = 0x03;// len
				tx_buf[1] = NRC;
				tx_buf[2] = sid;
				tx_buf[3] = NRC_INCORRECT_MESSAGE_LENGTH;
				UART_Send(tx_buf, 8);
		        continue;
	    	}
	    	else
	    	{
				switch(sub)
				{
					case DEFAULT_SESSION:
						Ecu_session = DEFAULT_SESSION;

						tx_buf[0] = 0x02; // LEN
						tx_buf[1] = SID_DIAG_SESSION + POS; // 0x50
						tx_buf[2] = DEFAULT_SESSION;

						UART_Send(tx_buf, 8);
						break;

					case PROGRAMMING_SESSION:
					    if (!sec_unlocked)
					    {
					        tx_buf[0] = 0x03;
					        tx_buf[1] = NRC;
					        tx_buf[2] = sid;
					        tx_buf[3] = NRC_SECURITY_ACCESS_DENIED;
					        UART_Send(tx_buf, 8);
					        break;
					    }
					    else if (speed != 0)
						{
							tx_buf[0] = 0x03;// len
							tx_buf[1] = NRC;
							tx_buf[2] = sid;
							tx_buf[3] = NRC_CONDITION_NOT_CORRECT;
							UART_Send(tx_buf, 8);
							break;
						}
						else
						{
							Ecu_session = PROGRAMMING_SESSION;

							tx_buf[0] = 0x02; // LEN
							tx_buf[1] = SID_DIAG_SESSION + POS; // 0x50
							tx_buf[2] = PROGRAMMING_SESSION;

							UART_Send(tx_buf, 8);
							break;
						}

					default:
						tx_buf[0] = 0x03;// len
						tx_buf[1] = NRC;
						tx_buf[2] = sid;
						tx_buf[3] = NRC_SUBFUNCTION_NOT_SUPPORTED;
						UART_Send(tx_buf, 8);
						break;
				}
				continue;
	    	}
	    }
	    else if (sid == SID_SECURITY)
	    {
	            SIGMA_SecurityAccess(len ,sub, data, tx_buf);
	            continue;
	    }

	    else if(sid == SID_RESET )
	    {
	    	if (Ecu_session != PROGRAMMING_SESSION)
	    	{
	    	    tx_buf[0] = 0x03;// len
	    	    tx_buf[1] = NRC;
	    	    tx_buf[2] = sid;
	    	    tx_buf[3] = NRC_SERVICE_NOT_SUPPORTED;
	    	    UART_Send(tx_buf, 8);
		    	continue;
	    	}
	    	if(len > 2)
	    	{
	    	    tx_buf[0] = 0x03;// len
	    	    tx_buf[1] = NRC;
	    	    tx_buf[2] = sid;
	    	    tx_buf[3] = NRC_INCORRECT_MESSAGE_LENGTH;
	    	    UART_Send(tx_buf, 8);
		    	continue;
	    	}
	    	else
	    	{
				switch(sub)
				{
					case SW_RESET:
						tx_buf[0] = 0x02;
						tx_buf[1] = SID_RESET + POS;
						tx_buf[2] = sub;
						UART_Send(tx_buf, 8);
						NVIC_SystemReset();
						break;
					case KEY_OFF_ON_RESET:
					case HW_RESET:
						if(flag == true)
						{
							tx_buf[0] = 0x02;
							tx_buf[1] = SID_RESET + POS;
							tx_buf[2] = sub;
							UART_Send(tx_buf, 8);
							NVIC_SystemReset();
							break;
						}
						else
						{
							tx_buf[0] = 0x03;// len
							tx_buf[1] = NRC;
							tx_buf[2] = sid;
							tx_buf[3] = NRC_CONDITION_NOT_CORRECT;
							UART_Send(tx_buf, 8);
							continue;
						}

					default :
						tx_buf[0] = 0x03;// len
						tx_buf[1] = NRC;
						tx_buf[2] = sid;
						tx_buf[3] = NRC_SUBFUNCTION_NOT_SUPPORTED;
						UART_Send(tx_buf, 8);
				}
	    	}
	    }

	    else
	    {
	    	tx_buf[0] = 0x03;// len
	    	tx_buf[1] = NRC;
	    	tx_buf[2] = sid;
	    	tx_buf[3] = NRC_SERVICE_NOT_SUPPORTED;
	    	UART_Send(tx_buf, 8);
	    }


    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

