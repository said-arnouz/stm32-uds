/*
 * uds_reset.c  –  FIXED
 *
 * FIX: Check req[1] subtype.  STM32 only supports hardReset (0x01).
 * Sending 11 02 or 11 03 now returns NRC_SUBFUNCTION_NOT_SUPPORTED
 * instead of silently jumping to the application.
 *
 * Also: response is sent BEFORE the jump so the host actually receives it.
 */

#include "flash_if.h"
#include "uds.h"
#include "uds_nrc.h"
#include "isotp.h"

void UDS_Reset(uint8_t *req, uint16_t len)
{
    if (len < 2)
        return UDS_SendNRC(0x11, NRC_INCORRECT_LENGTH);

    uint8_t sub = req[1];

    /* Only hardReset (0x01) supported in bootloader */
    if (sub != 0x01)
        return UDS_SendNRC(0x11, NRC_SUBFUNCTION_NOT_SUPPORTED);

    /* Positive response BEFORE jumping so host can receive it */
    uint8_t resp[2] = {0x51, sub};
    ISO_TP_Send(resp, 2);

    HAL_Delay(50);   /* give UART time to flush */

    Boot_JumpToApplication(APP_ADDRESS);
}
