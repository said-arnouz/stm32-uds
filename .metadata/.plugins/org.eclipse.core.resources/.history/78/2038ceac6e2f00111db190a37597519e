#ifndef ISOTP_H
#define ISOTP_H

#include <stdint.h>

/* ================= CONFIG ================= */
#define ISO_TP_FRAME_SIZE 8
#define ISO_TP_MAX_PAYLOAD 512

/* ================= PCI TYPES ================= */
#define ISO_TP_SF  0x00
#define ISO_TP_FF  0x10
#define ISO_TP_CF  0x20
#define ISO_TP_FC  0x30

/* ================= FLOW CONTROL ================= */
#define ISO_TP_FC_CTS 0x30   // Continue To Send
#define ISO_TP_FC_WAIT 0x31
#define ISO_TP_FC_OVFLW 0x32

/* ================= CONTEXT ================= */
typedef struct
{
    uint8_t buffer[ISO_TP_MAX_PAYLOAD];
    uint16_t length;
    uint16_t index;
    uint8_t state;
    uint8_t sequence_number;
} ISO_TP_Context_t;

/* ================= API ================= */
void ISO_TP_Init(void);
void ISO_TP_ProcessFrame(uint8_t *frame);
void ISO_TP_Send(uint8_t *data, uint16_t len);

/* ================= LOW LEVEL ================= */
void ISO_TP_SendFrame(uint8_t *frame);

/* ================= FLOW CONTROL ================= */
void ISO_TP_SendFC(void);

#endif /* INC_ISOTP_H_ */
