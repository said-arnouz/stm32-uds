#include "uds.h"
#include "uds_nrc.h"
#include "isotp.h"

void UDS_SendNRC(uint8_t sid, uint8_t nrc)
{
    uint8_t resp[3] = {0x7F, sid, nrc};
    ISO_TP_Send(resp, 3);
}

void UDS_Process(uint8_t *req, uint16_t len)
{
    uint8_t sid = req[0];

    switch(sid)
    {
        case 0x10: UDS_Session(req,len); break;
        case 0x11: UDS_Reset(req,len); break;
        case 0x27: UDS_Security(req,len); break;
        case 0x22: UDS_ReadDID(req,len); break;
        case 0x2E: UDS_WriteDID(req,len); break;
        case 0x34: UDS_RequestDownload(req,len); break;
        case 0x36: UDS_TransferData(req,len); break;
        case 0x37: UDS_RequestTransferExit(req,len); break;

        default:
            UDS_SendNRC(sid, NRC_SERVICE_NOT_SUPPORTED);
    }
}
