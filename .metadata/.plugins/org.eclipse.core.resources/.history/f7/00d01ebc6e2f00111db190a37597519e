/*
 * uds_flash.c  –  FIXED
 *
 * FIX 1 (TransferExit): Perform real CRC32 check instead of just checking
 *        the first word.  The host must send the expected CRC in the
 *        RequestDownload frame (bytes 6-9, big-endian) for this to work.
 *        If host sends 0 as CRC, the check is skipped (legacy mode).
 *
 * FIX 2 (RequestDownload): Store the host-supplied CRC from bytes [6..9].
 *
 * FIX 3 (TransferData): Wrap block counter correctly at 0xFF → 0x01
 *        (UDS spec: block counter 0x00 is reserved, wraps 0xFF→0x01).
 */

#include "uds.h"
#include "flash_if.h"
#include "uds_nrc.h"
#include "uds_types.h"
#include "isotp.h"

typedef struct {
    uint32_t base_addr;
    uint32_t total_size;
    uint32_t received;
    uint8_t  next_block;
    uint32_t expected_crc;
} Transfer_t;

static Transfer_t xfer;

/* ── SID 0x34  RequestDownload ───────────────────────────────────────── */
void UDS_RequestDownload(uint8_t *req, uint16_t len)
{
    if (!UDS_IsUnlocked())
        return UDS_SendNRC(0x34, NRC_SECURITY_ACCESS_DENIED);

    if (currentSession != SESSION_PROGRAMMING)
        return UDS_SendNRC(0x34, NRC_CONDITIONS_NOT_CORRECT);

    /* Minimum: SID(1) + dataFormatId(1) + memSize(4) = 6 bytes
     * Optional: + CRC32(4) = 10 bytes                           */
    if (len < 6)
        return UDS_SendNRC(0x34, NRC_INCORRECT_LENGTH);

    xfer.base_addr  = APP_ADDRESS;
    xfer.total_size = ((uint32_t)req[2] << 24)
                    | ((uint32_t)req[3] << 16)
                    | ((uint32_t)req[4] <<  8)
                    |  (uint32_t)req[5];
    xfer.received   = 0;
    xfer.next_block = 1;   /* first block is always 0x01 */

    /* FIX 2: read optional CRC from bytes [6..9] */
    if (len >= 10)
        xfer.expected_crc = ((uint32_t)req[6] << 24)
                          | ((uint32_t)req[7] << 16)
                          | ((uint32_t)req[8] <<  8)
                          |  (uint32_t)req[9];
    else
        xfer.expected_crc = 0;   /* 0 = skip CRC check */

    if (xfer.total_size == 0 || xfer.total_size > 0x60000)
        return UDS_SendNRC(0x34, NRC_REQUEST_OUT_OF_RANGE);

    if (Flash_Erase(xfer.base_addr) != FLASH_OK)
        return UDS_SendNRC(0x34, NRC_CONDITIONS_NOT_CORRECT);

    /* maxBlockLen field: 0x20 0x00 → up to 0x2000 bytes per block */
    uint8_t resp[3] = {0x74, 0x20, 0x00};
    ISO_TP_Send(resp, 3);
}

/* ── SID 0x36  TransferData ──────────────────────────────────────────── */
void UDS_TransferData(uint8_t *req, uint16_t len)
{
    if (len < 2)
        return UDS_SendNRC(0x36, NRC_INCORRECT_LENGTH);

    uint8_t block = req[1];

    if (block != xfer.next_block)
        return UDS_SendNRC(0x36, NRC_REQUEST_OUT_OF_RANGE);

    uint16_t data_len = len - 2;

    if (data_len == 0)
        return UDS_SendNRC(0x36, NRC_INCORRECT_LENGTH);

    if (xfer.received + data_len > xfer.total_size)
        return UDS_SendNRC(0x36, NRC_REQUEST_OUT_OF_RANGE);

    if (Flash_Write(xfer.base_addr + xfer.received, &req[2], data_len) != FLASH_OK)
        return UDS_SendNRC(0x36, NRC_CONDITIONS_NOT_CORRECT);

    xfer.received += data_len;

    /* FIX 3: block counter wraps 0xFF → 0x01 (0x00 is reserved per UDS spec) */
    xfer.next_block = (xfer.next_block == 0xFF) ? 0x01
                                                 : (xfer.next_block + 1);

    uint8_t resp[2] = {0x76, block};
    ISO_TP_Send(resp, 2);
}

/* ── SID 0x37  RequestTransferExit ──────────────────────────────────── */
void UDS_RequestTransferExit(uint8_t *req, uint16_t len)
{
    (void)req; (void)len;

    /* Check we received the declared amount */
    if (xfer.received != xfer.total_size)
        return UDS_SendNRC(0x37, NRC_CONDITIONS_NOT_CORRECT);

    /* FIX 1: CRC32 verification */
    if (xfer.expected_crc != 0)
    {
        uint8_t  *flash_ptr  = (uint8_t *)xfer.base_addr;
        uint32_t  actual_crc = stm32_crc32_sw(flash_ptr, xfer.total_size);

        if (actual_crc != xfer.expected_crc)
            return UDS_SendNRC(0x37, NRC_CONDITIONS_NOT_CORRECT);
    }
    else
    {
        /* Legacy: just make sure flash isn't empty */
        uint32_t first_word;
        Flash_Read(xfer.base_addr, (uint8_t *)&first_word, 4);
        if (first_word == 0xFFFFFFFF)
            return UDS_SendNRC(0x37, NRC_CONDITIONS_NOT_CORRECT);
    }

    uint8_t resp[1] = {0x77};
    ISO_TP_Send(resp, 1);
}
